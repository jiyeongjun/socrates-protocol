{
  "version": 4,
  "roles": {
    "fast_explorer": {
      "description": "Read-only discovery pass that recovers current state, target artifacts, protected surfaces, and narrow verification paths before asking the user or mutating.",
      "codex": {
        "preferred_models": [
          "gpt-5.6-luna",
          "gpt-5.6-terra",
          "gpt-5.6-sol",
          "gpt-5.4-mini",
          "gpt-5.5",
          "gpt-5.4",
          "gpt-5.3-codex-spark",
          "gpt-5.3-codex"
        ],
        "fallback_behavior": "host_default"
      },
      "claude": {
        "preferred_models": [
          "haiku",
          "sonnet"
        ],
        "fallback_behavior": "host_default_best_effort"
      }
    },
    "goal_contractor": {
      "description": "Read-only macro-contract pass that aligns the goal, scope, success criteria, non-goals, protected surfaces, verification, and one load-bearing unresolved question.",
      "codex": {
        "preferred_models": [
          "gpt-5.6-sol",
          "gpt-5.6-terra",
          "gpt-5.5",
          "gpt-5.4",
          "gpt-5.3-codex",
          "gpt-5.4-mini"
        ],
        "fallback_behavior": "host_default"
      },
      "claude": {
        "preferred_models": [
          "sonnet",
          "opus",
          "haiku"
        ],
        "fallback_behavior": "host_default_best_effort"
      }
    },
    "subgoal_planner": {
      "description": "Read-only decomposition pass that splits a macro contract into bounded, independently verifiable subcontracts.",
      "codex": {
        "preferred_models": [
          "gpt-5.6-terra",
          "gpt-5.6-sol",
          "gpt-5.5",
          "gpt-5.4",
          "gpt-5.4-mini",
          "gpt-5.3-codex"
        ],
        "fallback_behavior": "host_default"
      },
      "claude": {
        "preferred_models": [
          "sonnet",
          "opus",
          "haiku"
        ],
        "fallback_behavior": "host_default_best_effort"
      }
    },
    "protected_surface_planner": {
      "description": "Read-only planning pass for migrations, contracts, rollout, rollback, permissions, cost, and safety policy after exploration is in hand.",
      "codex": {
        "preferred_models": [
          "gpt-5.6-sol",
          "gpt-5.6-terra",
          "gpt-5.5",
          "gpt-5.4",
          "gpt-5.4-mini",
          "gpt-5.3-codex"
        ],
        "fallback_behavior": "host_default"
      },
      "claude": {
        "preferred_models": [
          "sonnet",
          "opus",
          "haiku"
        ],
        "fallback_behavior": "host_default_best_effort"
      }
    },
    "fast_verifier": {
      "description": "Cheap verification pass that runs the narrowest relevant checks first.",
      "codex": {
        "preferred_models": [
          "gpt-5.6-luna",
          "gpt-5.6-terra",
          "gpt-5.6-sol",
          "gpt-5.4-mini",
          "gpt-5.5",
          "gpt-5.4",
          "gpt-5.3-codex-spark",
          "gpt-5.3-codex"
        ],
        "fallback_behavior": "host_default"
      },
      "claude": {
        "preferred_models": [
          "haiku",
          "sonnet"
        ],
        "fallback_behavior": "host_default_best_effort"
      }
    },
    "contract_verifier": {
      "description": "Read-only closure gate that checks whether a subcontract or macro contract satisfies the documented completion and success criteria.",
      "codex": {
        "preferred_models": [
          "gpt-5.6-sol",
          "gpt-5.6-terra",
          "gpt-5.5",
          "gpt-5.4",
          "gpt-5.4-mini",
          "gpt-5.3-codex"
        ],
        "fallback_behavior": "host_default"
      },
      "claude": {
        "preferred_models": [
          "sonnet",
          "opus",
          "haiku"
        ],
        "fallback_behavior": "host_default_best_effort"
      }
    }
  },
  "rules": {
    "main_skill_artifacts_must_not_hardcode_model_names": true,
    "codex_binding_mode": "host_default_or_available_model_picker",
    "codex_reasoning_guidance": "preserve_baseline_then_compare_one_level_lower",
    "max_reasoning_requires_measured_quality_gain": true,
    "pro_mode_is_not_a_model_slug": true,
    "claude_binding_mode": "subagent_frontmatter_aliases_when_custom_agents_are_used",
    "host_default_fallback_is_allowed": true
  }
}
