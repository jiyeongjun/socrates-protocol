{
  "version": 5,
  "advisory_only": true,
  "runtime_binding": {
    "codex": "Generated .codex/agents/*.toml files request model, reasoning, and a read-only filesystem sandbox when that named agent is spawned; project trust and host precedence still apply, inherited tools may still exist, and they do not authorize external writes.",
    "claude": "Generated .claude/agents/*.md frontmatter requests model aliases, tools, and plan permission mode when that named agent is spawned; host model, organization, invocation, and parent-permission precedence still applies.",
    "model_policy_json": "Neither host consumes this file automatically. It documents fallbacks and evaluation policy only."
  },
  "roles": {
    "fast_explorer": {
      "codex_native_agent": "socrates-explore",
      "codex": {
        "preferred_models": [
          "gpt-5.6-terra",
          "gpt-5.6-sol",
          "gpt-5.6-luna",
          "gpt-5.4-mini",
          "gpt-5.5",
          "gpt-5.4",
          "gpt-5.3-codex-spark",
          "gpt-5.3-codex"
        ]
      },
      "claude_native_agent": "socrates-explore",
      "claude": {
        "preferred_models": ["haiku", "sonnet"]
      }
    },
    "goal_contractor": {
      "codex_native_agent": "socrates-plan",
      "codex": {
        "preferred_models": [
          "gpt-5.6-sol",
          "gpt-5.6-terra",
          "gpt-5.5",
          "gpt-5.4",
          "gpt-5.3-codex",
          "gpt-5.4-mini"
        ]
      },
      "claude_native_agent": "socrates-plan",
      "claude": {
        "preferred_models": ["sonnet", "opus", "haiku"]
      }
    },
    "subgoal_planner": {
      "codex_native_agent": "socrates-plan",
      "codex": {
        "preferred_models": [
          "gpt-5.6-terra",
          "gpt-5.6-sol",
          "gpt-5.5",
          "gpt-5.4",
          "gpt-5.4-mini",
          "gpt-5.3-codex"
        ]
      },
      "claude_native_agent": "socrates-plan",
      "claude": {
        "preferred_models": ["sonnet", "opus", "haiku"]
      }
    },
    "protected_surface_planner": {
      "codex_native_agent": "socrates-plan",
      "codex": {
        "preferred_models": [
          "gpt-5.6-sol",
          "gpt-5.6-terra",
          "gpt-5.5",
          "gpt-5.4",
          "gpt-5.4-mini",
          "gpt-5.3-codex"
        ]
      },
      "claude_native_agent": "socrates-plan",
      "claude": {
        "preferred_models": ["sonnet", "opus", "haiku"]
      }
    },
    "fast_verifier": {
      "codex_native_agent": "socrates-verify",
      "codex": {
        "preferred_models": [
          "gpt-5.6-terra",
          "gpt-5.6-sol",
          "gpt-5.6-luna",
          "gpt-5.4-mini",
          "gpt-5.5",
          "gpt-5.4",
          "gpt-5.3-codex-spark",
          "gpt-5.3-codex"
        ]
      },
      "claude_native_agent": "socrates-verify",
      "claude": {
        "preferred_models": ["haiku", "sonnet"]
      }
    },
    "contract_verifier": {
      "codex_native_agent": "socrates-evaluate",
      "codex": {
        "preferred_models": [
          "gpt-5.6-sol",
          "gpt-5.6-terra",
          "gpt-5.5",
          "gpt-5.4",
          "gpt-5.4-mini",
          "gpt-5.3-codex"
        ]
      },
      "claude_native_agent": "socrates-evaluate",
      "claude": {
        "preferred_models": ["sonnet", "opus", "haiku"]
      }
    }
  },
  "rules": {
    "codex_baseline_reasoning_effort": "high",
    "compare_one_level_lower": "medium",
    "max_reasoning_requires_measured_quality_gain": true,
    "gpt_5_6_pro_is_not_a_documented_model_slug": true,
    "do_not_prefer_luna_over_terra_without_eval": true,
    "preserve_legacy_fallbacks": true,
    "host_approval_always_wins": true
  }
}
